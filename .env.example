# ============================================================
# AWD Starter — Environment Variables
# Copy this file to .env.local and fill in real values.
# ============================================================

# ----- Site ------------------------------------------------
# Public URL of the site (used for metadata & OG tags)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_NAME="AWD Agency"
NEXT_PUBLIC_SITE_DESCRIPTION="Building modern web applications for your business."

# ----- Contact Form (Resend) --------------------------------
# https://resend.com — create a free account & API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Email address that receives contact form submissions
CONTACT_EMAIL=hello@yourdomain.com
# Verified sender address in Resend (must match your domain)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ----- Google Analytics 4 ----------------------------------
# Leave empty to disable GA4. Set to your Measurement ID to enable.
# Example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=
